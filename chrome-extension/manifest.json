{
  "manifest_version": 3,
  "name": "AI Resume Tool",
  "version": "1.0.0",
  "description": "Save LinkedIn jobs to AI Resume Tool",
  "permissions": ["activeTab", "scripting"],
  "host_permissions": [
    "https://www.linkedin.com/*",
    "http://localhost:3000/*"
  ],
  "action": {
    "default_popup": "src/popup/index.html"
  },
  "content_scripts": [
    {
      "matches": ["https://www.linkedin.com/jobs/*"],
      "js": ["src/content/index.js"]
    }
  ],
  "icons": {
    "128": "icons/icon.png"
  }
}
