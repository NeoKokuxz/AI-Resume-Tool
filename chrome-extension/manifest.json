{
  "manifest_version": 3,
  "name": "AI Resume Tool",
  "version": "1.0.0",
  "description": "Save LinkedIn jobs to AI Resume Tool",
  "permissions": ["activeTab", "scripting"],
  "host_permissions": [
    "https://www.linkedin.com/*",
    "http://localhost:3000/*"
  ],
  "action": {
    "default_popup": "popup.html"
  },
  "icons": {
    "128": "icons/icon.png"
  }
}
